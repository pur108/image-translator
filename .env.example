APP_ENV=local
HOST=0.0.0.0
PORT=8001

# Redis
REDIS_URL=redis://localhost:6379/0

# Translation provider: "deepl" or "openai"
TRANSLATION_PROVIDER=deepl

# DeepL (only needed if TRANSLATION_PROVIDER=deepl)
DEEPL_API_KEY=your-deepl-api-key
DEEPL_FREE_API=true

# OpenAI (only needed if TRANSLATION_PROVIDER=openai)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-5-nano

# Supabase (for URL validation)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_STORAGE_BUCKET=your-storage-bucket-name

# Processing
MAX_IMAGE_SIZE_BYTES=10485760
MAX_PROCESS_WIDTH=1280
FAST_INPAINT=true
RESULT_TTL_SECONDS=3600
FONT_DIR=./app/fonts
